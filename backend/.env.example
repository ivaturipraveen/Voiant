# ─── Anthropic / Claude ───────────────────────────────────────────────────────
# Required for live reasoning narratives + intent routing. If unset, the system
# falls back to deterministic narratives (numbers are identical either way).
ANTHROPIC_API_KEY=

# Model routing (Claude 4.6 / 4.8 family).
VOIANT_MODEL_DEFAULT=claude-sonnet-4-6
VOIANT_MODEL_COMPLEX=claude-opus-4-8

# ─── Bright Masker (PII detection + masking) — POST /mask ─────────────────────
BRIGHT_SHIELD_BASE_URL=https://36owxpb34jb9et-8000.proxy.runpod.net
BRIGHT_SHIELD_ENABLED=true
BRIGHT_SHIELD_TIMEOUT_SECONDS=60

# ─── Application ──────────────────────────────────────────────────────────────
# Active client config file (the "ledger"), relative to backend/config or absolute.
VOIANT_CONFIG_PATH=config/client_rapid7.yaml
# Local data dir for generated dataset snapshots + shield/audit sqlite.
VOIANT_DATA_DIR=data
# Synthetic dataset seed (deterministic).
VOIANT_DATASET_SEED=42

# ─── Data source (where the rep dataset comes from) ───────────────────────────
# synthetic → generated in-memory (default)
# csv       → read a spreadsheet of reps (set VOIANT_DATA_CSV_PATH)
# database  → read from a SQL database (set VOIANT_DATABASE_URL + VOIANT_DB_QUERY)
VOIANT_DATA_SOURCE=synthetic
VOIANT_DATA_CSV_PATH=data/reps.csv
# e.g. postgresql+psycopg2://user:pass@host:5432/dbname   (you'll share this URL)
VOIANT_DATABASE_URL=
# a table name (e.g. reps) or a full SELECT statement
VOIANT_DB_QUERY=reps
# CORS origin for the Vite dev server.
VOIANT_FRONTEND_ORIGIN=http://localhost:5173
