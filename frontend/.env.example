# Voiant frontend environment (Vite). Copy to .env.local and adjust as needed.
# Only VITE_-prefixed vars are exposed to the client bundle.

# Base URL of the FastAPI backend.
# - Dev: leave UNSET — requests go to "/api", which Vite proxies to the backend
#        (see vite.config.ts; default target http://localhost:8008).
# - Prod: set to the backend's public URL, e.g. https://voiant-backend.onrender.com
VITE_API_BASE=
