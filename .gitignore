# ─── Python ───────────────────────────────────────────────────────────────
.venv/
backend/.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv: commit uv.lock (this is an application, not a library) — do NOT ignore it.

# ─── Generated data / runtime artifacts (regenerated on boot) ───────────────
# Local SQLite DB (+ its -journal/-wal/-shm side-files) and cached snapshots.
# Schema is provisioned by Alembic at startup; the migrations themselves ARE tracked.
backend/data/*.sqlite*
backend/data/snapshot.json
backend/data/reps.json
backend/data/reps.csv

# ─── Secrets — NEVER commit ─────────────────────────────────────────────────
.env
*.env
!.env.example

# ─── Node / frontend build ──────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
*.tsbuildinfo

# ─── Editors / IDEs ─────────────────────────────────────────────────────────
.vscode/
.idea/

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store

# Internal reference docs (not for public repo)
docs/*.pdf
docs/*.docx
